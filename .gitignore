.env
__pycache__/
*.pyc
*.egg-info/
.venv/
venv/
.python-version

# llmwiki workspace-derived state (rebuilt by `llmwiki init`).
# We DO commit data/threads/wiki/ and data/raw/ — those ship with the
# repo so a fresh clone can serve and rebuild without re-scraping.
data/threads/.llmwiki/

# node_modules at repo root (repoview is fetched via npm install)
/node_modules/

# llmwiki runtime artifacts inside the vendored copy
llmwiki/api/.venv/
llmwiki/mcp/.venv/
llmwiki/node_modules/
llmwiki/web/node_modules/
llmwiki/web/.next/
llmwiki/web/.turbo/
llmwiki/api/__pycache__/
llmwiki/mcp/__pycache__/
